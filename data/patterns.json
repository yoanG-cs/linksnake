  "pathRules": [
    {
      "category": "Path Traversal",
      "pattern": "(\\.\\.\\/|\\.\\.\\\\|%2e%2e%2f|%2e%2e%5c|%2e%2e/|\\.\\.%2f|\\.\\.%5c)",
      "type": "regex",
      "severity": "critical",
      "note": "Attempt to access files outside the intended web directory."
    },
    {
      "category": "Sensitive Config/Secrets",
      "pattern": "(/\\.env(\\.local|\\.prod|\\.dev)?|/config\\.(php|json|yml|yaml)|/web\\.config|/settings\\.(json|py)|/\\.git/|/\\.ssh/|/phpinfo\\.php|/wp-config\\.php|/database\\.yml|/credentials)$",
      "type": "regex",
      "severity": "critical",
      "note": "Targeting server secrets, credentials, or environment variables."
    },
    {
      "category": "Web Shells/Backdoors",
      "pattern": "/(c99|r57|b374k|webshell|cmd|shell|WSO|indoxploit|wso2|alfa|FilesMan)\\.(php|jsp|aspx|asp|cfm)$",
      "type": "regex",
      "severity": "critical",
      "note": "Common names for uploaded attacker-controlled remote shell scripts."
    },
    {
      "category": "Social Engineering Keywords",
      "pattern": "/(update|patch|hotfix|invoice|billing|receipt|overdue|refund|payment|verification|security.?check|account.?suspended|confirm.?identity|urgent)/",
      "type": "regex",
      "severity": "medium",
      "note": "Urgency/authority keywords commonly used in phishing and malware delivery."
    },
    {
      "category": "Cloud Storage Direct Download Bypass",
      "pattern": "/(export=download|/uc\\?|/open\\?|confirm=t|view=download|action=direct)",
      "type": "regex",
      "severity": "high",
      "note": "URL patterns used to bypass Google Drive/Dropbox AV warning screens and force direct download."
    },
    {
      "category": "Suspicious Directory Patterns",
      "pattern": "/(wp-content/uploads/|/tmp/|/temp/|/pub/|/cache/|/uploads/|/files/|/attach/|/attachment/)",
      "type": "regex",
      "severity": "medium",
      "note": "Directories frequently used to host malware on compromised or poorly configured sites."
    },
    {
      "category": "URL Obfuscation / Encoding",
      "pattern": "(%[0-9a-fA-F]{2}){5,}|(%25){2,}|(%00)|(%0[aAdD])",
      "type": "regex",
      "severity": "high",
      "note": "Excessive or suspicious URL encoding used to obscure malicious destinations or bypass filters."
    },
    {
      "category": "IP Address URL",
      "pattern": "^/?(\\d{1,3}\\.){3}\\d{1,3}(:\\d+)?/",
      "type": "regex",
      "severity": "medium",
      "note": "Legitimate software is rarely delivered from a bare IP address. Common in malware C2 and exploit kits."
    },
    {
      "category": "Suspicious Archive with Executable Inside (Path hint)",
      "pattern": "/[^/]+\\.(zip|rar|7z|cab|iso|gz|tar\\.gz|tgz)/",
      "type": "regex",
      "severity": "low",
      "note": "Archive files served inline in a URL path — note for combined scoring, not blocking alone."
    },
    {
      "category": "Command Injection",
      "pattern": "(;|\\||`|\\$\\(|&&|\\|\\|)\\s*(cat|ls|id|whoami|uname|wget|curl|bash|sh|python|perl|ruby|nc|netcat|ncat|chmod|chown|rm\\s+-rf|/etc/passwd|/etc/shadow)",
      "type": "regex",
      "severity": "critical",
      "note": "Shell command injection patterns in URL — attempt to execute OS commands via web input."
    },
    {
      "category": "PHP Code Execution",
      "pattern": "(\\?|&)(cmd|exec|command|shell|system|passthru|eval|assert)=|eval\\(base64_decode\\(|system\\(|passthru\\(|shell_exec\\(",
      "type": "regex",
      "severity": "critical",
      "note": "PHP remote code execution parameters or function calls embedded in URL."
    },
    {
      "category": "Admin Panel Access",
      "pattern": "/(admin|administrator|wp-admin|phpmyadmin|adminer|cpanel|webmin|plesk|directadmin|manager|backend|controlpanel|adminpanel|wp-login\\.php)(/|$|\\?)",
      "type": "regex",
      "severity": "high",
      "note": "Access to administrative interfaces — high-value targets for credential stuffing and RCE."
    },
    {
      "category": "Known Exploit / CVE Paths",
      "pattern": "/(solr/admin|actuator/|console/login\\.jspa|wp-includes/ms-files\\.php|vendor/phpunit|eval-stdin\\.php|_fragment\\?|xmlrpc\\.php|joomla/administrator|sites/default/files|cgi-bin/(test-cgi|php\\.cgi)|showLogin\\.cc|tmUnblock\\.cgi)",
      "type": "regex",
      "severity": "critical",
      "note": "Paths associated with specific known CVEs and widely exploited CMS/framework vulnerabilities."
    },
    {
      "category": "SSRF / Internal Network Probe",
      "pattern": "(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|169\\.254\\.|10\\.\\d+\\.\\d+\\.\\d+|192\\.168\\.|172\\.(1[6-9]|2\\d|3[01])\\.|::1|\\[::1\\]|file://|gopher://|dict://|ftp://.*@)",
      "type": "regex",
      "severity": "high",
      "note": "Server-Side Request Forgery indicators — probing internal network or localhost services."
    },
    {
      "category": "SQL Injection Probe",
      "pattern": "('|%27|--|%2D%2D|/\\*|\\*/|xp_cmdshell|UNION(%20|\\+|%09)SELECT|SELECT(%20|\\+|%09).+FROM|INSERT(%20|\\+)INTO|DROP(%20|\\+)TABLE|OR(%20|\\+)1=1|AND(%20|\\+)1=1)",
      "type": "regex",
      "severity": "high",
      "note": "SQL injection payloads in URL — attempt to manipulate backend database queries."
    },
    {
      "category": "Log4Shell / Template Injection",
      "pattern": "(\\$\\{jndi:|\\$\\{\\$\\{|\\$\\{lower:|\\$\\{upper:|\\$\\{::-|\\#\\{|\\{\\{.*\\}\\}|<%=|<\\?=|\\{%|%7B%7B)",
      "type": "regex",
      "severity": "critical",
      "note": "Log4Shell (CVE-2021-44228) JNDI injection and generic template injection patterns."
    },
    {
      "category": "Cryptocurrency / Dropper Keywords",
      "pattern": "/(miner|mining|cryptominer|xmrig|monero|coinhive|coinimp|minexmr|claymore|nicehash|minergate|ethminer)(/|\\.|_|-|$)",
      "type": "regex",
      "severity": "high",
      "note": "Paths associated with cryptomining malware distribution or C2 endpoints."
    },
    {
      "category": "Credential / Token Leak in URL",
      "pattern": "(password|passwd|pwd|secret|api[_-]?key|token|auth[_-]?token|access[_-]?token|bearer|private[_-]?key)=[^&]{4,}",
      "type": "regex",
      "severity": "high",
      "note": "Credentials or tokens passed in URL query string — leaked in logs, referrer headers, and browser history."
    },
    {
      "category": "Malware Family Paths",
      "pattern": "/(gate\\.php|panel\\.php|bot\\.php|loader\\.php|payload\\.php|drop\\.php|inject\\.php|zeus|spyeye|citadel|emotet|trickbot|cobalt.?strike|meterpreter|beacon)(/|$|\\?|\\.)",
      "type": "regex",
      "severity": "critical",
      "note": "URL paths matching known malware family C2 endpoints and payload delivery scripts."
    }
  ]
}